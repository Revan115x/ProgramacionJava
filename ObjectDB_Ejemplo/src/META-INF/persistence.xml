<persistence xmlns="http://xmlns.jcp.org/xml/ns/persistence" version="2.1">
    <persistence-unit name="libros.odb">
        <provider>com.objectdb.jpa.Provider</provider>
        <class>objetodb.Libro</class>
        <properties>
            <property name="javax.persistence.jdbc.url" value="$objectdb/db/libros.odb"/>
        </properties>
    </persistence-unit>
</persistence>